# Green Compute System - Environment Configuration
# ================================================
# 复制此文件为 .env 并填入真实配置值
#   cp .env.example .env
#
# ⚠️ 安全提示：
#   - .env 文件包含敏感信息，请勿提交到 Git
#   - 数据库密码和 API Key 请联系作者获取
# ================================================

# PostgreSQL 连接字符串
# 格式: postgresql+psycopg2://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql+psycopg2://postgres:请联系作者获取密码@localhost:5432/green_compute

# DeepSeek API Key（智能问答功能需要）
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=请联系作者获取API_Key
